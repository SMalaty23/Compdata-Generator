{
  "identifier": "com.fce-creator.app",
  "productName": "FCE Creator",
  "version": "10.1.0",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "FCE Creator V10",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "targets": "all",
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}